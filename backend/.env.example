# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic | ollama
LLM_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (local models) — https://ollama.com
# Start Ollama, then pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_THINKING_BUDGET=512
LLM_EXPLANATION_MAX_TOKENS=900
LLM_SUMMARY_MAX_TOKENS=640

# Translation
# Choose one: libretranslate | none
TRANSLATION_PROVIDER=libretranslate
LIBRETRANSLATE_API_URL=http://127.0.0.1:5000/translate
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_CONCURRENCY=4
TRANSLATION_TIMEOUT_SECONDS=30

# ── Stockfish ─────────────────────────────────────────────────────────────────
# Windows example: d:\chess\Engines\stockfish.exe
# Mac/Linux: /usr/local/bin/stockfish  or just "stockfish" if in PATH
STOCKFISH_DEPTH=8
MAX_ANALYZED_PLAYER_MOVES=30
ENGINE_CANDIDATE_LINES=3
ENGINE_PV_MAX_MOVES=6
STOCKFISH_EVALUATE_BEST_MOVE=false
MIN_CRITICAL_EVAL_LOSS=100
STOCKFISH_PATH=stockfish
